# ucl-gpu-infra — shared secrets TEMPLATE.
#
# This file (the template) is committed and contains NO real values. To use it:
#   1. copy it to the canonical secret path (git-ignored, box-local):
#        mkdir -p ~/.config/ucl-gpu-infra
#        cp secrets.env.template ~/.config/ucl-gpu-infra/secrets.env
#   2. fill in the real values below
#   3. both consumers load it:  from ucl_gpu_infra import load_secrets; load_secrets()
#
# Override the path with $UCL_GPU_INFRA_SECRETS if you keep it elsewhere.
# NEVER commit the filled-in copy. The real secrets live in exactly one file on
# the box; memento-research and continual-auto-research both reference it.

# ── LLM: hosted API proxy (the `api` proposer / llm=api) ────────────────────
DEFAULT_API_PROVIDER=custom
CUSTOM_CHAT_CLASS=openai
DEFAULT_API_BASE_URL=https://your-llm-proxy.example/v1
DEFAULT_LLM_MODEL=your-model-name
CUSTOM_API_KEY=

# ── LLM: local Ollama on the box GPU (the `ollama`/`local` proposer) ─────────
# The api proposer above and ollama differ ONLY by base_url + model. Ollama runs
# behind the on-box wake-proxy (start-ollama-proxy.sh) on :11435.
OLLAMA_PROXY_URL=http://127.0.0.1:11435/v1
OLLAMA_MODEL=your-ollama-model

# ── GPU broker location ─────────────────────────────────────────────────────
# Where the broker scripts (claim-gpu.sh / release-gpu.sh / gpu-leases.sh) live
# on the box. REQUIRED for on-demand per-run GPU claiming — without it the broker
# falls back to the static shim below. (The package default is a generic
# ./ucl-infra so no personal path is baked into the public repo.)
UCL_INFRA_DIR=/path/to/ucl-infra
GPU_BROKER=1

# ── Experiment infra shim (the GPU broker / Stage-6 submission) ─────────────
# Static-shim fallback creds; the on-demand broker overrides these per run.
# This is the UCL path (e.g. http://127.0.0.1:8771 — the on-box shim tunnel).
INFRA_SERVER_URL=
INFRA_SESSION_KEY=

# ── H100 (direct) infra server — the `h100` runner ──────────────────────────
# The team H100 box. The H100 runner submits DIRECTLY here (no GPU broker lease),
# so it needs its own URL/key, kept separate from the UCL creds above. Mirrors the
# fork's env-profiles/infra.h100.env (INFRA_SERVER_URL=http://<h100-host>:<port>).
H100_INFRA_SERVER_URL=
H100_INFRA_SESSION_KEY=

# ── Optional ────────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=
# TALENT_MARKET_API_KEY=
